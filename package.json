{
  "name": "@hironytic/katazome",
  "version": "0.1.0",
  "packageManager": "npm@11.12.1",
  "description": "A CLI tool for generating source files from templates",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hironytic/katazome.git"
  },
  "type": "module",
  "bin": {
    "ktzm": "./src/cli.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "start": "node src/cli.ts",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.15.0",
      "onFail": "warn"
    }
  },
  "dependencies": {
    "commander": "^12.1.0",
    "json5": "^2.2.3",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.3.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^3.0.0"
  }
}
