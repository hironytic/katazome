// c-style setting (JSON5 format with comments)
{
  tagDefinition: {
    code: [
      { start: "/*{%", end: "%}*/" },
      { start: "/*{%-", end: "-%}*/", trim: "both" },
    ],
    comment: [
      { start: "/*{#", end: "#}*/" },
    ],
  },
  files: [
    {
      pattern: "*.c",
      tagDefinition: {
        value: [
          { start: "_V_", end: "_" },
          { start: "_V(\"", end: "\")" },
        ],
      },
    },
    {
      pattern: "*.ts",
      tagDefinition: {
        value: [
          { start: "_V_", end: "_" },
        ],
      },
    },
  ],
}
