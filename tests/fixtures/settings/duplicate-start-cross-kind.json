{
  "files": [
    {
      "pattern": "*.c",
      "tagDefinition": {
        "inherit": false,
        "code": [
          { "start": "/*{%", "end": "%}*/" }
        ],
        "value": [
          { "start": "/*{%", "end": "_" }
        ],
        "comment": [
          { "start": "/*{#", "end": "#}*/" }
        ]
      }
    }
  ]
}
