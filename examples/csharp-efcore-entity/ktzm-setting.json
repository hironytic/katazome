{
  "tagDefinition": {
    "code": [
      { "start": "/*{%", "end": "%}*/", "trim": "both" }
    ],
    "value": [
      { "start": "ZZ", "end": "__" },
      { "start": "zz", "end": "__" }
    ],
    "comment": [
      { "start": "/*{#", "end": "#}*/" }
    ]
  },
  "questions": [
    {
      "name": "name",
      "kind": "text",
      "type": "string",
      "message": "Entity name (space-separated words, e.g. \"user profile\")"
    },
    {
      "name": "namespace",
      "kind": "text",
      "type": "string",
      "message": "Namespace",
      "default": "MyApp.Models"
    }
  ],
  "exclude": ["case-converter.mts"],
  "imports": {
    "paths": [
      { "path": "./case-converter.mts", "as": "cc" }
    ]
  }
}
